# Machine-local path configuration — copy to local.env and edit.
#
# DATA_ROOT: base directory containing training data, tokenized data, and
#            tokenizers on this machine. All data paths in the repo are
#            relative to this root.
#
# The repo expects the following subdirectories under DATA_ROOT:
#   monolingual_training_data/          Raw text files (eng_latn.txt, etc.)
#   monolingual_training_data_bp/       Byte-premium train/eval splits
#   monolingual_training_data_tokenized/ Tokenized training data
#   monolingual-tokenizers/             Pretrained tokenizers
#     bpe_unscaled_tokenizers/
#     unigram_unscaled_tokenizers/
#
# Examples:
#   Bluehive cluster:  DATA_ROOT=/scratch/ssrivas9/catherinearnett
#   Docker / cloud:    DATA_ROOT=/root/data

DATA_ROOT=/path/to/your/data
